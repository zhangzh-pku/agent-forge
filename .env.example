# -----------------------------------------------------------------------------
# AgentForge environment configuration example
# -----------------------------------------------------------------------------

# Runtime mode: local (default) or aws
AGENTFORGE_RUNTIME=local
# Auth mode:
# - header: reads X-Tenant-Id / X-User-Id (local/dev)
# - trusted: reads X-Authenticated-Tenant-Id / X-Authenticated-User-Id from upstream authorizer
AGENTFORGE_AUTH_MODE=header

# HTTP server
PORT=8080

# Recovery scheduler (stale-run redrive + optional consistency check)
# - AGENTFORGE_RECOVERY_ENABLED=true to enable in cmd/taskapi background scheduler.
# - cmd/recovery runs one pass even when this is false.
# AGENTFORGE_RECOVERY_ENABLED=false
# AGENTFORGE_RECOVERY_INTERVAL=5m
# AGENTFORGE_RECOVERY_STALE_FOR=10m
# AGENTFORGE_RECOVERY_LIMIT=200
# AGENTFORGE_RECOVERY_TENANT_ID=
# AGENTFORGE_RECOVERY_CONSISTENCY_CHECK=false
# AGENTFORGE_RECOVERY_CONSISTENCY_REPAIR=false
# AGENTFORGE_RECOVERY_EVENT_COMPACTION_ENABLED=false
# AGENTFORGE_RECOVERY_EVENT_COMPACTION_WINDOW=24h

# LLM provider
AGENTFORGE_LLM_PROVIDER=mock
AGENTFORGE_LLM_MOCK_STEPS=3
AGENTFORGE_LLM_MODEL=gpt-4o-mini
# Optional routing defaults:
# - AGENTFORGE_LLM_ROUTING_DEFAULT_MODE supports: latency-first | quality-first | cost-cap
# - AGENTFORGE_LLM_FALLBACK_PROVIDERS is a comma-separated provider list (e.g. openai,mock)
# AGENTFORGE_LLM_ROUTING_DEFAULT_MODE=latency-first
# AGENTFORGE_LLM_FALLBACK_PROVIDERS=
# Optional model allowlist for request model_config validation (comma-separated).
# Defaults to a built-in safe set when unset.
# AGENTFORGE_ALLOWED_MODEL_IDS=gpt-4o-mini,gpt-4o,gpt-4.1,gpt-4,claude-3,claude-3-haiku,claude-3-sonnet,claude-3-opus
# Prompt policy (basic prompt-injection guardrails)
# AGENTFORGE_PROMPT_MAX_CHARS=16000
# AGENTFORGE_PROMPT_DENYLIST=ignore all previous instructions,reveal system prompt
# Optional per-model pricing overrides (USD per 1K tokens), comma-separated:
# AGENTFORGE_MODEL_PRICING_OVERRIDES=gpt-4o-mini=0.00035,gpt-4o=0.005,claude-3-sonnet=0.003
AGENTFORGE_LLM_TIMEOUT_SECONDS=60
# OPENAI_API_KEY=
# OPENAI_API_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:agentforge/openai-api-key-xxxxxx
# OPENAI_API_KEY_SECRET_FIELD=OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenTelemetry / tracing
# AGENTFORGE_OTEL_ENABLED=false
# AGENTFORGE_OTEL_SERVICE_NAME=agentforge-taskapi
# AGENTFORGE_OTEL_EXPORTER=none
# AGENTFORGE_OTEL_SAMPLE_RATIO=1.0

# -----------------------------------------------------------------------------
# AWS runtime (required when AGENTFORGE_RUNTIME=aws)
# -----------------------------------------------------------------------------
# TASKS_TABLE=agentforge-tasks-prod
# RUNS_TABLE=agentforge-runs-prod
# STEPS_TABLE=agentforge-steps-prod
# CONNECTIONS_TABLE=agentforge-connections-prod
# CONNECTIONS_TASK_INDEX=task-index
# TASK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/agentforge-tasks-prod
# ARTIFACTS_BUCKET=agentforge-artifacts-prod-123456789012
# ARTIFACT_SSE_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# WEBSOCKET_ENDPOINT=https://xxxx.execute-api.us-east-1.amazonaws.com/prod
# AGENTFORGE_EVENT_RETENTION=24h
# ARTIFACT_PRESIGN_EXPIRES=15m
# SQS_WAIT_TIME_SECONDS=20
# SQS_VISIBILITY_TIMEOUT_SECONDS=300
# SQS_MAX_MESSAGES=10
