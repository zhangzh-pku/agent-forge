# -----------------------------------------------------------------------------
# AgentForge environment configuration example
# -----------------------------------------------------------------------------

# Runtime mode: local (default) or aws
AGENTFORGE_RUNTIME=local

# HTTP server
PORT=8080

# LLM provider
AGENTFORGE_LLM_PROVIDER=mock
AGENTFORGE_LLM_MOCK_STEPS=3
AGENTFORGE_LLM_MODEL=gpt-4o-mini
AGENTFORGE_LLM_TIMEOUT_SECONDS=60
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# AWS runtime (required when AGENTFORGE_RUNTIME=aws)
# -----------------------------------------------------------------------------
# TASKS_TABLE=agentforge-tasks-prod
# RUNS_TABLE=agentforge-runs-prod
# STEPS_TABLE=agentforge-steps-prod
# CONNECTIONS_TABLE=agentforge-connections-prod
# CONNECTIONS_TASK_INDEX=task-index
# TASK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/agentforge-tasks-prod
# ARTIFACTS_BUCKET=agentforge-artifacts-prod-123456789012
# WEBSOCKET_ENDPOINT=https://xxxx.execute-api.us-east-1.amazonaws.com/prod
# ARTIFACT_PRESIGN_EXPIRES=15m
# SQS_WAIT_TIME_SECONDS=20
# SQS_VISIBILITY_TIMEOUT_SECONDS=300
# SQS_MAX_MESSAGES=10
